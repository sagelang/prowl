// Boolean logic and comparisons.
// Returns 1 (true) as the exit code if all assertions hold.

fn all_true(a: Bool, b: Bool, c: Bool) -> Bool {
    return a && b && c;
}

fn main() -> Int {
    let x: Int = 42;
    let big: Bool = x > 10;
    let even: Bool = x == 42;
    let not_zero: Bool = !(x == 0);

    if all_true(big, even, not_zero) {
        return 1;
    }
    return 0;
}
